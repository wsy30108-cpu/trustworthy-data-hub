# ===== Label Studio ML Backend Settings =====

# Service listen host & port
ML_HOST=0.0.0.0
ML_PORT=9090

# Model identifier returned to Label Studio
MODEL_VERSION=pre-label-v1

# Label Studio instance (used to fetch tasks / images when needed)
# Example: http://label-studio:8080
LABEL_STUDIO_URL=http://localhost:8080

# Label Studio API token (create one in LS -> Account & Settings -> Access Token)
LABEL_STUDIO_API_KEY=

# Optional shared secret used to authenticate webhook / predict requests.
# Leave empty to disable auth.
ML_SHARED_SECRET=
